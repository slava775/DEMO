<Page x:Class="Demo.Pages.Content.AddPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Demo.Pages.Content"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" Width="233" Margin="0 0 20 0">
                <StackPanel>
                    <TextBlock Text="Название товара:" Margin="0 10 0 5" FontSize="15"/>
                    <TextBox x:Name="TbNameTovar" Height="25" FontSize="15"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Цена товара:" Margin="0 10 0 5" FontSize="15"/>
                    <TextBox x:Name="TbPrice" Height="25" FontSize="15"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Классификация товара:" Margin="0 10 0 5" FontSize="15"/>
                    <ComboBox x:Name="CbClassification" Height="25" FontSize="15"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Описание товара:" Margin="0 10 0 5" FontSize="15"/>
                    <TextBox x:Name="TbDescription" Height="55" FontSize="15" TextWrapping="Wrap" MaxLength="100"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20 0 0 0">
                <TextBlock Text="Выберете изображение:" FontSize="15" Margin="0 0 0 5"/>
                <Border BorderThickness="1" BorderBrush="Black" Height="150" Width="200" CornerRadius="10">
                    <Image x:Name="ImageService" Stretch="Uniform"/>
                </Border>
                <Button x:Name="BtnSelectPhoto" Content="Выбере фото" FontWeight="Bold" Width="195" Height="25" Margin="0 10 0 0" Click="BtnSelectPhoto_Click"/>
            </StackPanel>
        </Grid>
        <Button x:Name="BtnSave" Grid.Row="1" Content="Сохранить" FontWeight="Bold" Padding="10 5" Margin="15" HorizontalAlignment="Center" Click="BtnSave_Click"/>
    </Grid>
</Page>
