<Page x:Class="Demo.Pages.Content.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Demo.Pages.Content"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage">

    <Grid>
        <Border BorderThickness="1" BorderBrush="Black" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20" CornerRadius="10">
            <StackPanel>
                <StackPanel Width="150">
                    <Image x:Name="ImageService" Source="/Assets/ИконкаПрофиляДефолт.png" Stretch="Uniform"/>
                </StackPanel>
                <StackPanel Width="220">
                    <StackPanel>
                        <TextBlock Text="Имя:" FontSize="25" Margin="0 0 0 5"/>
                        <TextBox x:Name="TbName" Height="30" Padding="5"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Фамилия:" FontSize="25" Margin="0 0 0 5"/>
                        <TextBox x:Name="TbSurname" Height="30" Padding="5"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Логин:" FontSize="25" Margin="0 0 0 5"/>
                        <TextBox x:Name="TbLogin" Height="30" Padding="5"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel>
                    <Button x:Name="BtnSave" Content="Сохранить" Height="40" Padding="5" FontSize="20" Margin="0 10 0 5" Click="BtnSave_Click"/>
                    <Button x:Name="BtnEnitPhoto" Content="Изменить фото" Height="40" Padding="5" FontSize="20" Click="BtnEnitPhoto_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
