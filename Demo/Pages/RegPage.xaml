<Page x:Class="Demo.Pages.RegPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Demo.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegPage">

    <Grid>
        <Border BorderThickness="1" BorderBrush="Black" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20" CornerRadius="10">
            <StackPanel>
                <TextBlock Text="Регистрация" FontSize="45" FontWeight="Bold" Margin="0 0 0 15"/>
                <StackPanel>
                    <TextBlock Text="Логин:" FontSize="25" Margin="0 0 0 5"/>
                    <TextBox x:Name="TbLogin" Height="30" Padding="5"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Имя:" FontSize="25" Margin="0 0 0 5"/>
                    <TextBox x:Name="TbName" Height="30" Padding="5"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Фамилия:" FontSize="25" Margin="0 0 0 5"/>
                    <TextBox x:Name="TbSurName" Height="30" Padding="5"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Пароль:" FontSize="25" Margin="0 0 0 5"/>
                    <TextBox x:Name="TbPassword" Height="30" Padding="5"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Повтор пароля:" FontSize="25" Margin="0 0 0 5"/>
                    <TextBox x:Name="TbRepeatPassword" Height="30" Padding="5"/>
                </StackPanel>
                <Button x:Name="BtnReg" Content="Зарегестрироваться" Height="40" Padding="5" FontSize="20" FontWeight="Bold" Margin="0 15 0 10" Click="BtnReg_Click"/>
                <StackPanel>
                    <TextBlock HorizontalAlignment="Center">
                        <Run Text="Уже есть аккаунт?" FontSize="15"/>
                        <Run Text="Войти" FontSize="15" FontWeight="Bold" Cursor="Arrow" MouseDown="Run_MouseDown"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
